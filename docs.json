{
  "$schema": "https://mintlify.com/schema.json",
  "name": "C2C Platform",
  "theme": "linden",
  "logo": {
    "dark": "/logo/logo-dark.svg",
    "light": "/logo/logo-light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "topbarLinks": [
    {
      "name": "Support",
      "url": "mailto:support@c2cplatform.com"
    }
  ],
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://dashboard.c2cplatform.com"
  },
  "api": {
    "baseUrl": "https://ca-c2c-dev-api.calmsea-c64629ed.uaenorth.azurecontainerapps.io",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    },
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "javascript", "python"],
      "defaults": "required",
      "prefill": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Integration Guides",
            "pages": ["guides/server-integration"]
          },
          {
            "group": "Reference",
            "pages": ["errors", "rate-limits", "idempotency", "webhooks"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      }
    ]
  },
  "footerSocials": {
    "github": "https://github.com/c2cplatform"
  }
}
